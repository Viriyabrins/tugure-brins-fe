# SSL certificate paths (absolute paths)
# Update these if you move the cert files elsewhere on disk
#SSL_KEY_PATH=/app/src/cert/server-dev.key
#SSL_CERT_PATH=/app/src/cert/server-dev.crt
# Optional CA bundle (absolute)
# SSL_CA_PATH=/app/src/cert/ca.crt

# Keycloak Signature Token
# Digunakan oleh server.js (Node) sebagai KEYCLOAK_SECRET_KEY
# Digunakan oleh Frontend (Vite) sebagai VITE_KEYCLOAK_SECRET_KEY
KEYCLOAK_SECRET_KEY="bP9W7Rgm+TW99+gswnTRhWXqEEWv0GpMKX7e3FxjVxw="
VITE_KEYCLOAK_SECRET_KEY="bP9W7Rgm+TW99+gswnTRhWXqEEWv0GpMKX7e3FxjVxw="

# Signature expiry timeout (ms). Server dan Frontend HARUS sama nilainya.
SIGNATURE_MAX_AGE_MS=5000
VITE_SIGNATURE_MAX_AGE_MS=5000

