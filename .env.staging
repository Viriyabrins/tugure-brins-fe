DATABASE_URL="postgresql://postgres:admin1234@10.10.5.8:5445/viriya?schema=brins"
VITE_APP_ID=brin-app-dev
VITE_USE_BACKEND_API=true

# Staging server / proxy configuration for `server.js`
PORT=10010
HOST=0.0.0.0
PROXY_TARGET=http://202.155.91.210:10011
PROXY_PREFIX=/api
# Frontend API configuration
VITE_API_PROXY=/api
VITE_API_BASE_URL=/api
CORS_ORIGIN=*
VITE_DIST_PATH=./dist

# Keycloak configuration
VITE_KEYCLOAK_URL=https://202.155.91.210:9003
VITE_KEYCLOAK_REALM=brins
VITE_KEYCLOAK_CLIENT_ID=brins-tugure
